BACKEND_PORT=8000

# Local development via kubectl port-forward:
# kubectl port-forward svc/team5-postgres 5433:5432 -n skala3-finalproj-class2-team5
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=safety
SERVICE_APP_USER=safety_service_app
SERVICE_APP_PASSWORD=change-me-service-app-password

# Local development via kubectl port-forward:
# kubectl port-forward svc/team5-minio 9000:9000 -n skala3-finalproj-class2-team5
APP_MINIO_ENDPOINT=http://localhost:9000
APP_MINIO_BUCKET=safety-files
APP_MINIO_ACCESS_KEY=change-me-minio-access-key
APP_MINIO_SECRET_KEY=change-me-minio-secret-key

APP_JWT_SECRET=change-me-random-secret-at-least-32-bytes
APP_AUTH_COOKIE_SECURE=false
APP_AUTH_COOKIE_SAME_SITE=Lax
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Local FastAPI, when available.
APP_FASTAPI_BASE_URL=http://localhost:8001
